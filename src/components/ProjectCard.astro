---
import { Image } from "astro:assets";

export interface ProjectCardData {
  title: string;
  description?: string;
  technologies?: string[];
  link?: string;
  preview?: string;
  status?: string;
  date?: string;
  /** Bundled image (preferred — gets optimized) */
  image?: ImageMetadata;
  /** Fallback: render an initials gradient header instead of an image */
  initials?: string;
}

interface Props {
  project: ProjectCardData;
}

const { project } = Astro.props;

const hasCode = project.link && project.link !== "#";
const hasPreview = project.preview && project.preview !== "#";
const isPrivate = !hasCode && !hasPreview;

const statusTone =
  project.status === "Live"
    ? "bg-green-500/15 text-green-400 border-green-500/30"
    : project.status === "Private"
      ? "bg-amber-500/15 text-amber-400 border-amber-500/30"
      : "bg-[var(--sec)]/15 text-[var(--accent-2)] border-[var(--sec)]/30";

const initials =
  project.initials ??
  project.title
    .split(/[\s-]+/)
    .map((w) => w[0])
    .filter(Boolean)
    .slice(0, 3)
    .join("")
    .toUpperCase();
---

<article
  class="group glass edge-light rounded-2xl overflow-hidden flex flex-col transition-all duration-300 hover:-translate-y-1"
>
  <!-- Header / media -->
  <div class="relative overflow-hidden">
    {
      project.image ? (
        <Image
          src={project.image}
          alt={project.title}
          class="w-full h-48 md:h-56 object-cover transition-transform duration-500 group-hover:scale-105"
        />
      ) : (
        <div class="relative w-full h-44 md:h-52 bg-gradient-to-br from-[#6366f1] via-[#3b82f6] to-[#06b6d4] flex items-center justify-center overflow-hidden">
          <span class="absolute text-7xl font-bold text-white/15 select-none tracking-tight">
            {initials}
          </span>
          <span class="relative z-10 px-6 text-center text-white text-lg md:text-xl font-semibold leading-snug">
            {project.title}
          </span>
        </div>
      )
    }

    {
      project.status && (
        <span
          class={`absolute top-3 right-3 flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-semibold border backdrop-blur-sm ${statusTone}`}
        >
          {project.status === "Live" && (
            <span class="relative flex h-2 w-2">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75" />
              <span class="relative inline-flex rounded-full h-2 w-2 bg-green-500" />
            </span>
          )}
          {project.status}
        </span>
      )
    }
  </div>

  <!-- Body -->
  <div class="flex flex-col flex-grow p-5 md:p-6">
    <div class="flex items-start justify-between gap-3 mb-2">
      <h4 class="text-lg md:text-xl font-semibold text-[var(--white)] leading-snug">
        {project.title}
      </h4>
      {project.date && (
        <span class="text-xs text-[var(--white-icon)] whitespace-nowrap mt-1">
          {project.date}
        </span>
      )}
    </div>

    {
      project.description && (
        <p class="text-sm text-[var(--white-icon)] leading-relaxed mb-4">
          {project.description}
        </p>
      )
    }

    {
      project.technologies && project.technologies.length > 0 && (
        <div class="flex flex-wrap gap-2 mb-5">
          {project.technologies.map((tech) => (
            <span class="px-2.5 py-1 bg-[var(--sec)]/10 text-[var(--white)] rounded-md text-xs font-medium border border-[var(--sec)]/25">
              {tech}
            </span>
          ))}
        </div>
      )
    }

    <!-- Actions pinned to bottom -->
    <div class="flex gap-3 mt-auto">
      {
        hasCode && (
          <a
            href={project.link}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="View source code"
            class="flex-1 flex justify-center items-center gap-2 py-2.5 px-4 text-[var(--white-icon)] hover:text-white transition duration-300 border border-[var(--border)] hover:border-[var(--border-hover)] rounded-xl bg-[rgba(13,18,32,0.5)] hover:bg-[var(--surface-hover)]"
          >
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4">
              <path d="M12.001 2C6.47598 2 2.00098 6.475 2.00098 12C2.00098 16.425 4.86348 20.1625 8.83848 21.4875C9.33848 21.575 9.52598 21.275 9.52598 21.0125C9.52598 20.775 9.51348 19.9875 9.51348 19.15C7.00098 19.6125 6.35098 18.5375 6.15098 17.975C6.03848 17.6875 5.55098 16.8 5.12598 16.5625C4.77598 16.375 4.27598 15.9125 5.11348 15.9C5.90098 15.8875 6.46348 16.625 6.65098 16.925C7.55098 18.4375 8.98848 18.0125 9.56348 17.75C9.65098 17.1 9.91348 16.6625 10.201 16.4125C7.97598 16.1625 5.65098 15.3 5.65098 11.475C5.65098 10.3875 6.03848 9.4875 6.67598 8.7875C6.57598 8.5375 6.22598 7.5125 6.77598 6.1375C6.77598 6.1375 7.61348 5.875 9.52598 7.1625C10.326 6.9375 11.176 6.825 12.026 6.825C12.876 6.825 13.726 6.9375 14.526 7.1625C16.4385 5.8625 17.276 6.1375 17.276 6.1375C17.826 7.5125 17.476 8.5375 17.376 8.7875C18.0135 9.4875 18.401 10.375 18.401 11.475C18.401 15.3125 16.0635 16.1625 13.8385 16.4125C14.201 16.725 14.5135 17.325 14.5135 18.2625C14.5135 19.6 14.501 20.675 14.501 21.0125C14.501 21.275 14.6885 21.5875 15.1885 21.4875C19.259 20.1133 21.9999 16.2963 22.001 12C22.001 6.475 17.526 2 12.001 2Z" />
            </svg>
            <span class="text-sm">Code</span>
          </a>
        )
      }
      {
        hasPreview && (
          <a
            href={project.preview}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Live preview"
            class="flex-1 flex justify-center items-center gap-2 py-2.5 px-4 text-white transition duration-300 border border-[var(--sec)]/40 rounded-xl bg-[var(--sec)]/15 hover:bg-[var(--sec)]/25"
          >
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4">
              <path d="M16.0037 9.41421L7.39712 18.0208L5.98291 16.6066L14.5895 8H7.00373V6H18.0037V17H16.0037V9.41421Z" />
            </svg>
            <span class="text-sm">Live</span>
          </a>
        )
      }
      {
        isPrivate && (
          <div class="flex-1 flex justify-center items-center gap-2 py-2.5 px-4 text-[var(--white-icon)] opacity-60 border border-[var(--border)] rounded-xl bg-[rgba(13,18,32,0.5)]">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4">
              <path d="M6 10V15H8V10H6ZM10 10V15H12V10H10ZM14 10V15H16V10H14ZM18 6V8H6V6H7V4C7 3.44772 7.44772 3 8 3H16C16.5523 3 17 3.44772 17 4V6H18ZM9 4V6H15V4H9Z" />
            </svg>
            <span class="text-sm">Private Repository</span>
          </div>
        )
      }
    </div>
  </div>
</article>
