---
interface NavItem {
  label: string;
  href: string;
  icon: string;
}

const navItems: NavItem[] = [
  {
    label: "Home",
    href: "/",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="24" height="24" fill="currentColor"><path d="M21 20C21 20.5523 20.5523 21 20 21H4C3.44772 21 3 20.5523 3 20V9.48907C3 9.18048 3.14247 8.88917 3.38606 8.69972L11.3861 2.47749C11.7472 2.19663 12.2528 2.19663 12.6139 2.47749L20.6139 8.69972C20.8575 8.88917 21 9.18048 21 9.48907V20ZM19 19V9.97815L12 4.53371L5 9.97815V19H19Z"></path></svg>`,
  },
  {
    label: "Projects",
    href: "/projects",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="24" height="24" fill="currentColor"><path d="M4 5V19H20V7H11.5858L9.58579 5H4ZM12.4142 5H21C21.5523 5 22 5.44772 22 6V20C22 20.5523 21.5523 21 21 21H3C2.44772 21 2 20.5523 2 20V4C2 3.44772 2 3 3 3H10.4142L12.4142 5Z"></path></svg>`,
  },
  {
    label: "Experience",
    href: "/experience",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="24" height="24" fill="currentColor"><path d="M7 5V2C7 1.44772 7.44772 1 8 1H16C16.5523 1 17 1.44772 17 2V5H21C21.5523 5 22 5.44772 22 6V20C22 20.5523 21.5523 21 21 21H3C2.44772 21 2 20.5523 2 20V6C2 5.44772 2.44772 5 3 5H7ZM4 13V19H20V13H15V15H9V13H4ZM4 7V11H9V9H15V11H20V7H4ZM9 3V5H15V3H9Z"></path></svg>`,
  },
  {
    label: "Resume",
    href: "https://drive.google.com/file/d/1lnqf0yg6h3lhwFaTqIhon7LYjHKr9WHV/view?usp=sharing",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16c0 1.1.9 2 2 2h12a2 2 0 0 0 2-2V8l-6-6z"/><path d="M14 3v5h5M16 13H8M16 17H8M10 9H8"/></svg>`,
  },
  {
    label: "Links",
    href: "/links",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="24" height="24" fill="currentColor"><path d="M4 5V19H20V7H11.5858L9.58579 5H4ZM12.4142 5H21C21.5523 5 22 5.44772 22 6V20C22 20.5523 21.5523 21 21 21H3C2.44772 21 2 20.5523 2 20V4C2 3.44772 2.44772 3 3 3H10.4142L12.4142 5Z"></path></svg>`,
  },
  {
    label: "Contact",
    href: "/#contact",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="24" height="24" fill="currentColor"><path d="M21.7267 2.95694L16.2734 22.0432C16.1225 22.5716 15.7979 22.5956 15.5563 22.1126L11 13L1.9229 9.36919C1.41322 9.16532 1.41953 8.86022 1.95695 8.68108L21.0432 2.31901C21.5716 2.14285 21.8747 2.43866 21.7267 2.95694ZM19.0353 5.09647L6.81221 9.17085L12.4488 11.4255L15.4895 17.5068L19.0353 5.09647Z"></path></svg>`,
  },
];
---

<div class="flex justify-center w-full">
  <nav
    id="main-nav"
    class="fixed left-0 right-0 z-[100] text-[var(--white)] md:top-0 md:bottom-auto bottom-0 md:w-auto md:mt-5 md:justify-self-center"
  >
    <ul
      id="nav-list"
      class="relative flex w-full justify-between md:justify-center items-stretch md:gap-1 gap-0 px-1.5 md:px-2 py-2 md:py-2 bg-[rgba(13,18,32,0.7)] border border-[var(--border)] md:rounded-2xl rounded-t-2xl backdrop-blur-2xl"
    >
      <!-- Sliding active pill (positioned relative to this <ul>) -->
      <span
        id="nav-indicator"
        aria-hidden="true"
        class="absolute top-2 bottom-2 left-0 rounded-xl opacity-0 z-0 pointer-events-none"
      ></span>

      {
        navItems.map((item, index) => (
          <li class="flex-1 md:flex-none">
            <a
              href={item.href}
              data-nav-item={index}
              class="nav-link relative z-10 flex flex-col md:flex-row items-center justify-center gap-1 text-[var(--white-icon)] hover:text-[var(--white)] transition-colors duration-300 text-sm md:text-[0.95rem] md:px-4 px-1 md:py-2 py-2 rounded-xl"
              target={item.href.startsWith('http') ? '_blank' : '_self'}
              rel={item.href.startsWith('http') ? 'noopener noreferrer' : ''}
            >
              <span class="md:hidden flex items-center justify-center w-6 h-6">
                <fragment set:html={item.icon} />
              </span>
              <span class="hidden md:inline-block font-medium tracking-wide">{item.label}</span>
              <span class="md:hidden text-[0.65rem] font-medium">{item.label}</span>
            </a>
          </li>
        ))
      }
    </ul>
  </nav>
</div>

<script>
  // Lightweight, robust nav: the pill is positioned inside the <ul> using
  // offsetLeft/offsetWidth (immune to padding/transform), so it never smears.
  function initNav() {
    const list = document.getElementById('nav-list');
    const indicator = document.getElementById('nav-indicator');
    const links = Array.from(document.querySelectorAll<HTMLAnchorElement>('.nav-link'));
    if (!list || !indicator || links.length === 0) return;

    let current = 0;

    const moveIndicator = (el: HTMLElement | null, animate = true) => {
      if (!el) return;
      indicator.style.transition = animate
        ? 'transform 0.45s cubic-bezier(0.22, 1, 0.36, 1), width 0.45s cubic-bezier(0.22, 1, 0.36, 1), opacity 0.3s ease'
        : 'none';
      indicator.style.width = `${el.offsetWidth}px`;
      indicator.style.transform = `translateX(${el.offsetLeft}px)`;
      indicator.style.opacity = '1';
    };

    const setActive = (index: number, animate = true) => {
      current = index;
      links.forEach((link, i) => link.classList.toggle('active', i === index));
      moveIndicator(links[index], animate);
    };

    const activeFromLocation = () => {
      const path = window.location.pathname.replace(/\/$/, '') || '/';
      const hash = window.location.hash;
      let idx = 0;
      links.forEach((link, i) => {
        const href = link.getAttribute('href') || '';
        if (href.startsWith('http')) return; // external links never "active"
        const cleanHref = href.replace(/\/$/, '');
        if (cleanHref === path) idx = i;
        // sub-routes (e.g. /projects/systems) highlight their section root
        else if (cleanHref !== '/' && cleanHref && path.startsWith(cleanHref + '/')) idx = i;
        else if (path === '/' && href.startsWith('/#') && hash && href.endsWith(hash)) idx = i;
      });
      return idx;
    };

    // Smooth scroll for in-page hash links + active update on click
    links.forEach((link, index) => {
      link.addEventListener('click', (e) => {
        const href = link.getAttribute('href') || '';
        if (href.startsWith('/#')) {
          const target = document.getElementById(href.substring(2));
          if (target) {
            e.preventDefault();
            const top = target.getBoundingClientRect().top + window.scrollY - 90;
            window.scrollTo({ top, behavior: 'smooth' });
            history.pushState(null, '', href);
          }
        }
        setActive(index);
      });
    });

    // Scroll-spy on the homepage
    if ((window.location.pathname.replace(/\/$/, '') || '/') === '/') {
      const sections = document.querySelectorAll('section[id]');
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (!entry.isIntersecting) return;
            const id = entry.target.getAttribute('id');
            const i = links.findIndex((l) => l.getAttribute('href') === `/#${id}`);
            if (i !== -1 && i !== current) setActive(i);
          });
        },
        { threshold: 0.35, rootMargin: '-90px 0px -45% 0px' }
      );
      sections.forEach((s) => observer.observe(s));
    }

    // Initial placement (no animation), then enable transitions
    requestAnimationFrame(() => {
      setActive(activeFromLocation(), false);
      requestAnimationFrame(() => moveIndicator(links[current], false));
    });

    window.addEventListener('popstate', () => setActive(activeFromLocation()));
    window.addEventListener('resize', () => moveIndicator(links[current], false));
    window.addEventListener('load', () => moveIndicator(links[current], false));
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initNav);
  } else {
    initNav();
  }
</script>

<style>
  @media (max-width: 767px) {
    body {
      padding-bottom: 84px;
    }
  }

  /* Entrance animation lives on the inner <ul>, NOT on the fixed <nav>.
     A lingering transform on a position:fixed element breaks viewport
     pinning (it becomes the containing block), so the nav must stay
     transform-free. */
  #nav-list {
    animation: navIn 0.7s cubic-bezier(0.22, 1, 0.36, 1) both;
    animation-delay: 0.3s;
  }
  @keyframes navIn {
    from { opacity: 0; transform: translateY(-16px); }
    to { opacity: 1; transform: translateY(0); }
  }
  @media (max-width: 767px) {
    @keyframes navIn {
      from { opacity: 0; transform: translateY(16px); }
      to { opacity: 1; transform: translateY(0); }
    }
  }

  #nav-list {
    box-shadow:
      0 12px 40px -8px rgba(0, 0, 0, 0.5),
      inset 0 1px 0 rgba(255, 255, 255, 0.06);
  }

  #nav-indicator {
    background: linear-gradient(120deg, rgba(99, 102, 241, 0.95), rgba(6, 182, 212, 0.9));
    box-shadow:
      0 6px 20px -4px rgba(99, 102, 241, 0.5),
      inset 0 1px 0 rgba(255, 255, 255, 0.25);
  }

  .nav-link.active {
    color: #ffffff !important;
    font-weight: 600;
  }
</style>
