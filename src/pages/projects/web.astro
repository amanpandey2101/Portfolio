---
import ProjectsDetail from "@/components/ProjectsDetail.astro";
import ProjectCard, { type ProjectCardData } from "@/components/ProjectCard.astro";

import dashboard from "../../../public/projects/web/dashboard.jpg";
import forms from "../../../public/projects/web/forms.jpg";

const projects: ProjectCardData[] = [
    {
        title: "HAKS — Digital Welfare Infrastructure",
        image: dashboard as ImageMetadata,
        link: "#",
        preview: "#",
        status: "Private",
        technologies: ["MERN Stack", "React Native", "MongoDB", "Express", "Node.js"],
        description:
            "A cross-platform digital ecosystem (Web + Mobile) streamlining record management and benefit disbursement for martyrs' families, replacing manual legacy workflows for the Indian Army. Officially recognized by the Bihar Regiment.",
        date: "2023 – 2024",
    },
    {
        title: "HAKS — Automated Document Synthesis",
        image: forms as ImageMetadata,
        link: "#",
        preview: "#",
        status: "Private",
        technologies: ["MERN Stack", "Node.js", "PDF Generation"],
        description:
            "An automated document synthesis engine generating pre-filled welfare forms — reducing grievance-filing latency and improving data accuracy for stakeholders.",
        date: "2023 – 2024",
    },
];
---

<ProjectsDetail
    pageTitle="Aman Kumar Pandey | MERN Stack"
    heading="MERN Stack"
    intro="Web and mobile apps built on the MERN stack — including welfare infrastructure recognized by the Indian Army."
>
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 md:gap-8">
        {projects.map((project) => <ProjectCard project={project} />)}
    </div>
</ProjectsDetail>
