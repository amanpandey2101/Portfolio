---
import ProjectsDetail from "@/components/ProjectsDetail.astro";
import ProjectCard, { type ProjectCardData } from "@/components/ProjectCard.astro";

import diffuze from "../../../public/projects/shopify/home.jpg";
import sixty9ine from "../../../public/projects/shopify/sxity9ine.jpg";

const projects: ProjectCardData[] = [
    {
        title: "Diffuz — Shopify Store",
        image: diffuze as ImageMetadata,
        preview: "https://diffuze.in",
        link: "https://diffuze.in",
        status: "Live",
        description: "Car-fragrance and home-fragrance e-commerce storefront built on Shopify.",
        technologies: ["Shopify", "Liquid", "E-commerce"],
        date: "2024",
    },
    {
        title: "Sixty9ine — Shopify Store",
        image: sixty9ine as ImageMetadata,
        preview: "https://sixty9ine.com",
        link: "https://sixty9ine.com",
        status: "Live",
        description: "T-shirt and hoodie apparel store built and customized on Shopify.",
        technologies: ["Shopify", "Liquid", "E-commerce"],
        date: "2024",
    },
];
---

<ProjectsDetail
    pageTitle="Aman Kumar Pandey | Shopify"
    heading="Shopify"
    intro="Custom Shopify storefronts — design, theme customization, and live e-commerce deployments."
>
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 md:gap-8">
        {projects.map((project) => <ProjectCard project={project} />)}
    </div>
</ProjectsDetail>
