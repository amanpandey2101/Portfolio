---
import ProjectsDetail from "@/components/ProjectsDetail.astro";
import ProjectCard, { type ProjectCardData } from "@/components/ProjectCard.astro";

import threddit from "../../../public/projects/aiml/threddit-home.jpg";
import answer from "../../../public/projects/aiml/home-git.jpg";
import jora from "../../../public/projects/aiml/Jora.jpg";
import scrapi from "../../../public/projects/aiml/home-hero.jpg";

const projects: ProjectCardData[] = [
    {
        title: "Scrapi - AI-Powered Web Scraping",
        image: scrapi as ImageMetadata,
        link: "https://github.com/amanpandey2101/scrapify",
        preview: "https://scrapify-flow.vercel.app/",
        status: "Live",
        technologies: ["NextJS", "Shadcn UI", "NeonDB", "PostgreSQL", "React Flow", "Clerk"],
        description:
            "A highly customizable, visual web scraper built with Next.js, PostgreSQL, Prisma, and React Flow. Users compose complex scraping workflows in a no-code/low-code canvas, with AI-based data extraction baked in.",
        date: "2025",
    },
    {
        title: "Threddit - Reddit Clone",
        image: threddit as ImageMetadata,
        link: "https://github.com/amanpandey2101/threddit",
        preview: "https://threddit.vercel.app/",
        status: "Live",
        technologies: ["NextJS", "Shadcn UI", "NeonDB", "Vercel AI SDK", "Clerk"],
        description:
            "A full-stack Reddit clone using Clerk for auth, the Vercel AI SDK to auto-flag inappropriate or sensitive posts, and Sanity as a headless CMS.",
        date: "2025",
    },
    {
        title: "AI Github SaaS",
        image: answer as ImageMetadata,
        link: "https://github.com/amanpandey2101/ai-github-saas",
        preview: "https://ai-github-talk.vercel.app/",
        status: "Live",
        technologies: ["NextJS", "Langchain", "AssemblyAI", "OpenAI", "TypeScript"],
        description:
            "AI-powered GitHub SaaS where users link repos, ask natural-language questions, get code-level answers with file highlights, collaborate, and auto-generate issue summaries from meeting audio.",
        date: "2025",
    },
    {
        title: "Jora - Jira Clone",
        image: jora as ImageMetadata,
        link: "https://github.com/amanpandey2101/jora",
        preview: "https://jora-one.vercel.app/",
        status: "Live",
        technologies: ["NextJS", "Clerk", "NeonDB", "PostgreSQL", "Tailwind CSS"],
        description:
            "A full-featured project-management app inspired by Jira, with user authentication and robust database persistence.",
        date: "2024",
    },
];
---

<ProjectsDetail
    pageTitle="Aman Kumar Pandey | NextJS AI SaaS"
    heading="NextJS AI SaaS"
    intro="Full-stack, AI-powered products shipped end to end — from auth and data to LLM-driven features and live deployments."
>
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 md:gap-8">
        {projects.map((project) => <ProjectCard project={project} />)}
    </div>
</ProjectsDetail>
