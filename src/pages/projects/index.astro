---
import Nav from "@/components/nav.astro";
import Layout from "@/layouts/Layout.astro";
import favicon from "/favicons/main.ico";
import Folder from "../../React/Folder";
import SplashCursor from "../../React/SplashCursor";

interface FolderItem {
    color: string;
    images: string[];
    icon: string;
    label: string;
    link: string;
    blurb: string;
}

const folders: FolderItem[] = [
    {
        color: "#18181b90",
        images: [
            "/projects/aiml/home-git.jpg",
            "/projects/aiml/home-hero.jpg",
            "/projects/aiml/answer.jpg",
        ],
        icon: "/icons/python.png",
        label: "AI & Backend Systems",
        link: "/projects/systems",
        blurb: "Agents, RAG & cloud/edge infra",
    },
    {
        color: "#18181b90",
        images: [
            "/projects/aiml/Jora.jpg",
            "/projects/aiml/home-git.jpg",
            "/projects/aiml/threddit-home.jpg",
        ],
        icon: "/icons/globe.png",
        label: "NextJS AI SaaS",
        link: "/projects/ai",
        blurb: "Full-stack AI products",
    },
    {
        color: "#18181b90",
        images: [
            "/projects/web/martyrs.jpg",
            "/projects/web/dashboard.jpg",
            "/projects/web/forms.jpg",
        ],
        label: "MERN Stack",
        icon: "/icons/react.png",
        link: "/projects/web",
        blurb: "Web & mobile apps",
    },
    {
        color: "#18181b90",
        images: [
            "/projects/shopify/home.jpg",
            "/projects/shopify/sxity9ine.jpg",
            "/projects/shopify/home.jpg",
        ],
        icon: "/icons/misc.png",
        label: "Shopify",
        link: "/projects/shopify",
        blurb: "E-commerce storefronts",
    },
];
---

<Layout title="Aman Kumar Pandey | Projects" favicon={favicon}>
    <Nav />
    <div class="absolute inset-0 -z-10">
        <SplashCursor client:load />
    </div>

    <section
        class="relative z-10 w-full min-h-screen flex flex-col items-center justify-center text-[var(--white)] px-4 py-28 md:py-24"
        id="home"
    >
        <!-- Header -->
        <header class="text-center max-w-2xl mb-20 md:mb-28">
            <h2 class="text-lg text-[var(--sec)] mb-3 shiny-sec">My work</h2>
            <h1 class="text-4xl md:text-6xl font-medium text-gradient w-fit mx-auto pb-1">
                Projects
            </h1>
            <p class="text-[var(--white-icon)] mt-4 leading-relaxed">
                A collection of things I've built — from AI infrastructure and autonomous
                agents to full-stack products and storefronts. Pick a folder to explore.
            </p>
        </header>

        <!-- Folder gallery -->
        <div
            class="grid grid-cols-2 lg:grid-cols-4 gap-x-10 gap-y-24 md:gap-x-20 md:gap-y-28 place-items-center"
        >
            {
                folders.map((folder) => (
                    <div class="flex flex-col items-center text-center gap-3">
                        <Folder
                            client:load
                            size={1.4}
                            color={folder.color}
                            images={folder.images}
                            label={folder.label}
                            className="custom-folder"
                            link={folder.link}
                        />
                        <p class="text-xs md:text-sm text-[var(--white-icon)] max-w-[10rem] mt-6 md:mt-8">
                            {folder.blurb}
                        </p>
                    </div>
                ))
            }
        </div>
    </section>
</Layout>
