---
import { inject } from "@vercel/analytics";
import { fade } from "astro:transitions";
import Aurora from "../React/Aurora.tsx";
import ClickSpark from "@/React/ClickSpark";
inject();

// import DisableDevtool from 'disable-devtool';
// if (!import.meta.env.SSR) {
//   DisableDevtool();
// }

interface Props {
  title: string;
  favicon: string;
}

const { title, favicon } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Software Developer" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href={favicon} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Montserrat:ital,wght@0,100..900;1,100..900&display=swap"
    />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Montserrat:ital,wght@0,100..900;1,100..900&display=swap"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link
        rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Montserrat:ital,wght@0,100..900;1,100..900&display=swap"
      />
    </noscript>

    <title>{title}</title>
  </head>
  <body class="bg-[#0a0e16] md:px-48 lg:px-20 overflow-x-hidden relative">
    <ClickSpark
  sparkColor='#22d3ee'
  sparkSize={10}
  sparkRadius={15}
  sparkCount={8}
  duration={400}
>
    <!-- Aurora Background -->
    <Aurora
      client:load
      colorStops={["#6366f1", "#3b82f6", "#06b6d4"]}
      amplitude={1.1}
      blend={0.55}
      speed={0.7}
    />
    
    <!-- Main Content -->
    <div class="relative z-10">
      <slot />
    </div>
  </ClickSpark>
    <!-- <Analytics /> -->
  </body>
</html>

<style is:global>
  :root {
    /* Core palette — Indigo → Cyan on slate-black */
    --background: #0a0e16;
    --background-soft: #0d1220;

    --sec: #6366f1;            /* primary accent (indigo) */
    --sec-rgb: 99, 102, 241;
    --accent-2: #06b6d4;       /* secondary accent (cyan) */
    --accent-2-rgb: 6, 182, 212;
    --accent-glow: rgba(99, 102, 241, 0.35);
    --gradient: linear-gradient(120deg, #6366f1 0%, #3b82f6 50%, #06b6d4 100%);

    --white: #f1f5f9;
    --white-icon: #94a3b8;
    --white-icon-tr: rgba(148, 163, 184, 0.12);

    /* Surfaces */
    --surface: rgba(17, 24, 39, 0.55);
    --surface-hover: rgba(30, 41, 59, 0.65);
    --border: rgba(148, 163, 184, 0.12);
    --border-hover: rgba(99, 102, 241, 0.45);
  }

  * {
    font-family:
      "montserrat",
      -apple-system,
      system-ui,
      sans-serif;
    box-sizing: border-box;
    padding: 0;
    margin: 0;
  }

  *::selection {
    background-color: var(--sec);
    color: #ffffff;
  }

  html {
    scroll-behavior: smooth;
  }

  /* Ensure content is visible over aurora */
  body {
    position: relative;
    min-height: 100vh;
    color: var(--white);
    background:
      radial-gradient(1200px 600px at 80% -10%, rgba(99, 102, 241, 0.08), transparent 60%),
      radial-gradient(900px 500px at 0% 20%, rgba(6, 182, 212, 0.06), transparent 55%),
      var(--background);
  }

  /* ---- Reusable modern utilities ---- */

  /* Gradient text */
  .text-gradient {
    background: var(--gradient);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  /* Animated shiny gradient (used by .shiny-sec across pages) */
  .shiny-sec {
    background: linear-gradient(120deg, #6366f1 20%, #22d3ee 50%, #6366f1 80%);
    background-size: 300% 100%;
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    animation: shine 4s linear infinite;
  }
  .shiny-white {
    background: linear-gradient(120deg, #cbd5e1 30%, #ffffff 50%, #cbd5e1 70%);
    background-size: 300% 100%;
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    animation: shine 5s linear infinite;
  }
  @keyframes shine {
    0% { background-position: 200% 50%; }
    100% { background-position: -100% 50%; }
  }

  /* Glass card surface */
  .glass {
    background: var(--surface);
    backdrop-filter: blur(20px) saturate(140%);
    -webkit-backdrop-filter: blur(20px) saturate(140%);
    border: 1px solid var(--border);
    border-radius: 1.25rem;
    transition: border-color 0.35s ease, background 0.35s ease, transform 0.35s ease, box-shadow 0.35s ease;
  }
  .glass:hover {
    border-color: var(--border-hover);
    background: var(--surface-hover);
    box-shadow: 0 10px 40px -12px var(--accent-glow);
  }

  /* Subtle top-edge highlight for premium feel */
  .edge-light {
    position: relative;
  }
  .edge-light::before {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: inherit;
    padding: 1px;
    background: linear-gradient(140deg, rgba(99,102,241,0.5), transparent 35%, transparent 65%, rgba(6,182,212,0.4));
    -webkit-mask: linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    opacity: 0;
    transition: opacity 0.35s ease;
    pointer-events: none;
  }
  .edge-light:hover::before {
    opacity: 1;
  }

  /* Keep legacy translucent card surfaces consistent with the new theme.
     Use :where() with an escaped attr-style class via [class] matching so the
     CSS parser accepts it and the glassmorphism is applied site-wide. */
  [class~="bg-[#1414149c]"] {
    background: var(--surface) !important;
    backdrop-filter: blur(20px) saturate(140%) !important;
    -webkit-backdrop-filter: blur(20px) saturate(140%) !important;
    border-color: var(--border);
  }
  /* Card-like surfaces only — never the <body>, whose backdrop-filter would
     become the containing block for position:fixed children (breaks the nav). */
  :not(body)[class~="bg-[#0a0a0a]"],
  :not(body)[class~="bg-[#0a0e16]"] {
    background: rgba(10, 14, 22, 0.85) !important;
    backdrop-filter: blur(16px) !important;
    -webkit-backdrop-filter: blur(16px) !important;
  }

  /* Scrollbar styles */
  ::-webkit-scrollbar {
    width: 12px;
  }
  ::-webkit-scrollbar-track {
    background: rgba(13, 18, 32, 0.5);
  }
  ::-webkit-scrollbar-thumb {
    background: linear-gradient(var(--sec), var(--accent-2));
    border-radius: 10px;
    border: 3px solid transparent;
    background-clip: padding-box;
  }
  ::-webkit-scrollbar-thumb:hover {
    background: linear-gradient(#818cf8, #22d3ee);
    background-clip: padding-box;
  }
  * {
    scrollbar-width: thin;
    scrollbar-color: var(--sec) rgba(13, 18, 32, 0.5);
  }
</style>